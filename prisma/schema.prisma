// Multi-tenant B2B SaaS data model.
//
// Tenancy model: shared database, shared schema. Every tenant-owned table
// carries the tenant key (`organization_id`) and is protected by Postgres
// Row-Level Security (see prisma/migrations/*_rls). The "tenant id" in this
// codebase IS the Organization id.
//
// Tenant-owned tables (RLS-protected): organizations, memberships, boards.
// Global tables (no tenant scoping): users — a person can belong to many orgs.
//
// Migrations and the seed script connect as `saas_owner` (DATABASE_URL), the
// table owner, which bypasses RLS. Runtime queries connect as `saas_app`
// (APP_DATABASE_URL) via withTenant(), which is fully subject to RLS.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime/admin (owner) connection. In production this is the POOLED,
  // transaction-mode connection string (e.g. Neon's `-pooler` host).
  url      = env("DATABASE_URL")
  // Direct (non-pooled, session) connection used by Prisma Migrate and
  // introspection. Migrations need session-level features (advisory locks) that
  // a transaction-mode pooler doesn't support. In local dev DIRECT_URL can be
  // the same value as DATABASE_URL. See .env.example / ARCHITECTURE.md.
  directUrl = env("DIRECT_URL")
}

/// A person. Global identity — not tenant-scoped. Belongs to zero or more
/// organizations through Membership.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  // bcrypt hash. Nullable so future federated (OAuth) users can exist without a
  // password; the Credentials provider rejects sign-in when it is null.
  passwordHash String? @map("password_hash")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships Membership[]
  posts       Post[]
  votes       Vote[]
  comments    Comment[]

  @@map("users")
}

/// The tenant. All tenant-owned rows point back to an Organization.
///
/// Billing is per-organization: the Organization is the Stripe *customer*. The
/// `plan`/`subscriptionStatus` columns are the app's source of truth for what
/// the tenant is entitled to, kept in sync from Stripe webhooks (see
/// app/api/stripe/webhook). They are written only by the owner/system path.
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // --- Billing (Stripe) -----------------------------------------------------
  /// The Stripe Customer id for this org (`cus_…`). Null until first checkout.
  stripeCustomerId String? @unique @map("stripe_customer_id")
  /// The active Stripe Subscription id (`sub_…`). Null when on FREE.
  stripeSubscriptionId String? @unique @map("stripe_subscription_id")
  /// Entitlement tier. Gated features read this. Defaults to FREE.
  plan Plan @default(FREE)
  /// Raw Stripe subscription status (e.g. active, trialing, past_due,
  /// canceled). Informational; `plan` is what enforcement checks.
  subscriptionStatus String? @map("subscription_status")

  memberships Membership[]
  boards      Board[]
  posts       Post[]
  votes       Vote[]
  comments    Comment[]

  @@map("organizations")
}

/// Join table between User and Organization, carrying the user's role within
/// that specific organization. Tenant-owned.
model Membership {
  id             String   @id @default(cuid())
  role           Role     @default(MEMBER)
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A user has at most one membership (and thus one role) per organization.
  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@map("memberships")
}

/// A board belonging to an organization. Tenant-owned domain object — the
/// placeholder "real" entity that proves the stack end to end.
model Board {
  id   String @id @default(cuid())
  name String
  /// URL slug, unique within the organization. Generated from the name; part of
  /// the public URL /b/{orgSlug}/{boardSlug}.
  slug String
  /// When true the board is viewable on the public, unauthenticated route.
  /// Private boards 404 there. Defaults to private.
  isPublic       Boolean  @default(false) @map("is_public")
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  posts        Post[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("boards")
}

/// A feedback/roadmap post inside a board. Tenant-owned. Carries
/// `organization_id` directly (not only via its board) so the same RLS
/// `tenant_isolation` policy applies to it as to every other tenant table.
model Post {
  id             String     @id @default(cuid())
  title          String
  description    String?
  status         PostStatus @default(OPEN)
  boardId        String     @map("board_id")
  organizationId String     @map("organization_id")
  /// Author user id. Null for anonymous public submissions.
  authorId       String?    @map("author_id")
  /// Optional contact email captured from an anonymous public submission.
  submitterEmail String?    @map("submitter_email")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  board        Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)
  votes        Vote[]
  comments     Comment[]

  @@index([boardId])
  @@index([organizationId])
  @@index([authorId])
  @@map("posts")
}

/// One upvote on a post — by a signed-in user (userId) OR an anonymous public
/// visitor (visitorId, a signed cookie value). Exactly one of the two is set.
/// The two unique constraints enforce one-vote-per-post for each identity kind;
/// nulls are distinct in Postgres, so the unused column never collides.
model Vote {
  id             String   @id @default(cuid())
  postId         String   @map("post_id")
  userId         String?  @map("user_id")
  visitorId      String?  @map("visitor_id")
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")

  post         Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@unique([postId, visitorId])
  @@index([postId])
  @@index([organizationId])
  @@map("votes")
}

/// A comment on a post. Tenant-owned. Written by a signed-in member (authorId)
/// or an anonymous public visitor (authorName, optional). `parentId` gives one
/// level of "threaded-lite" replies.
model Comment {
  id             String   @id @default(cuid())
  body           String
  postId         String   @map("post_id")
  organizationId String   @map("organization_id")
  /// Author user id, or null for an anonymous public comment.
  authorId       String?  @map("author_id")
  /// Display name for an anonymous comment (falls back to "Anonymous").
  authorName     String?  @map("author_name")
  /// Parent comment for a reply; null for a top-level comment.
  parentId       String?  @map("parent_id")
  createdAt      DateTime @default(now()) @map("created_at")

  post         Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)
  parent       Comment?     @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[]    @relation("CommentReplies")

  @@index([postId])
  @@index([organizationId])
  @@index([parentId])
  @@map("comments")
}

enum Role {
  OWNER
  MEMBER
}

/// Subscription entitlement tier for an Organization.
enum Plan {
  FREE
  PRO
}

/// Roadmap status for a Post.
enum PostStatus {
  OPEN
  PLANNED
  IN_PROGRESS
  DONE
}
