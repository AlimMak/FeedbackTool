# ---------------------------------------------------------------------------
# Database connections
#
# This app uses TWO Postgres roles to enforce tenant isolation via RLS:
#
#   * saas_owner  -> owns the tables. Used for migrations and the seed script,
#                    and for trusted "system" queries. As the table owner it
#                    BYPASSES Row-Level Security. This is DATABASE_URL and is
#                    also what Prisma Migrate uses.
#
#   * saas_app    -> the runtime application role. NOT a table owner and has no
#                    BYPASSRLS attribute, so every query it runs is filtered by
#                    the RLS policies. This is APP_DATABASE_URL.
#
# Tenant-scoped requests at runtime must go through APP_DATABASE_URL wrapped in
# withTenant(), which sets the `app.current_tenant` session variable that the
# RLS policies read. See ARCHITECTURE.md.
# ---------------------------------------------------------------------------

# Owner / migration / seed connection (bypasses RLS).
DATABASE_URL="postgresql://saas_owner:owner_pw@localhost:5432/saas_dev?schema=public"

# Runtime application connection (RLS enforced).
APP_DATABASE_URL="postgresql://saas_app:app_pw@localhost:5432/saas_dev?schema=public"

# Auth.js (NextAuth) secret used to sign/encrypt the session JWT.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"
