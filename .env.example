# ===========================================================================
# Environment variables. Copy to `.env` for local dev; in production set these
# in your host's dashboard (e.g. Vercel → Project → Settings → Environment
# Variables). NEVER commit real secrets — `.env` is gitignored.
# ===========================================================================

# ---------------------------------------------------------------------------
# Database — two Postgres ROLES enforce tenant isolation via RLS:
#
#   * saas_owner  -> owns the tables. Migrations, seed, and trusted "system"
#                    queries (webhooks, cross-tenant lookups). As table owner it
#                    BYPASSES Row-Level Security.  => DATABASE_URL / DIRECT_URL
#   * saas_app    -> the runtime app role. Not owner, NOSUPERUSER, NOBYPASSRLS,
#                    so every query it runs is filtered by RLS.  => APP_DATABASE_URL
#
# ...and two CONNECTION KINDS in production (serverless + pooling):
#
#   * POOLED (transaction mode)  -> used at runtime. REQUIRED for RLS to work
#     under serverless: withTenant() sets `app.current_tenant` with SET LOCAL
#     inside one transaction, which is safe only on a transaction-mode pooler.
#   * DIRECT (session)           -> used by `prisma migrate deploy` (migrations
#     need advisory locks a transaction pooler can't provide).
#
# LOCAL DEV (Docker or scripts/bootstrap-local.sh): there's no pooler, so the
# pooled and direct URLs are identical.
# ---------------------------------------------------------------------------

# Owner connection, POOLED. Runtime admin/system client + Prisma's default.
DATABASE_URL="postgresql://saas_owner:owner_pw@localhost:5432/saas_dev?schema=public"

# Owner connection, DIRECT (non-pooled). Used only by Prisma Migrate.
# Local dev: same as DATABASE_URL. Neon: use the NON-pooler host.
DIRECT_URL="postgresql://saas_owner:owner_pw@localhost:5432/saas_dev?schema=public"

# Runtime app connection (saas_app), POOLED. RLS enforced.
APP_DATABASE_URL="postgresql://saas_app:app_pw@localhost:5432/saas_dev?schema=public"

# --- Neon (production) example --------------------------------------------
# Create a `saas_app` role in Neon's SQL editor (see README), then use the
# POOLED host (contains `-pooler`) for the runtime URLs and the plain host for
# DIRECT_URL. Add `?sslmode=require` (and `&pgbouncer=true` on the pooled URLs):
#
# DATABASE_URL="postgresql://saas_owner:***@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://saas_owner:***@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
# APP_DATABASE_URL="postgresql://saas_app:***@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# ---------------------------------------------------------------------------
# Auth.js (NextAuth) — secret that signs/encrypts the session JWT.
# Generate one with:  openssl rand -base64 32
# Use a DIFFERENT value in production and keep it secret.
# ---------------------------------------------------------------------------
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# Absolute base URL of the app. Local: http://localhost:3000. Production: your
# deployed origin, e.g. https://your-app.vercel.app (no trailing slash). Used to
# build Stripe redirect URLs and the public board embed snippet.
APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Stripe billing.
#
# DEVELOPMENT: use TEST-mode keys (sk_test_… / whsec_… from `stripe listen`).
# PRODUCTION: use LIVE-mode keys (sk_live_…) and the LIVE webhook signing secret
# from the dashboard webhook endpoint. The code path is identical; only the keys
# differ. Keep live keys in your host's secret store, never in the repo.
# ---------------------------------------------------------------------------

# Secret key. Test: sk_test_… (https://dashboard.stripe.com/test/apikeys).
# Live: sk_live_… (https://dashboard.stripe.com/apikeys).
STRIPE_SECRET_KEY="sk_test_PASTE_YOUR_SECRET_KEY_HERE"

# PRO plan price id (price_…). Run `npm run stripe:setup` (against whichever mode
# your STRIPE_SECRET_KEY is in) and paste the printed id.
STRIPE_PRICE_PRO="price_PASTE_THE_PRO_PRICE_ID"

# Webhook signing secret (whsec_…). It authenticates incoming webhooks.
#   * Local dev:  stripe listen --forward-to localhost:3000/api/webhooks/stripe
#     and paste the whsec_… it prints.
#   * Production: register an endpoint at  {APP_URL}/api/webhooks/stripe  in the
#     Stripe dashboard (Developers → Webhooks) and paste its "Signing secret".
STRIPE_WEBHOOK_SECRET="whsec_PASTE_YOUR_WEBHOOK_SIGNING_SECRET"

# ---------------------------------------------------------------------------
# First-run admin (used ONLY by `npm run create-admin`, not by the app at
# runtime). Creates your first real organization + owner login in production
# instead of seeding fake demo data. Leave blank in dev.
# ---------------------------------------------------------------------------
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_ORG_NAME=""
